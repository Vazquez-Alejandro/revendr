rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin users collection - users can read/write their own doc
    match /usuarios_admin/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Campaigns collection
    match /campanias/{campaignId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Global leads collection
    match /leads/{leadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Products collection
    match /productos/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Demo configurations
    match /config_demos/{nicheId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Public demos (for demo pages)
    match /demos/{demoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Landing views tracking
    match /landing_views/{viewId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Landing engagement tracking
    match /landing_engagement/{engagementId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Revenue tracking
    match /revenue/{revenueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
