rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin users collection - users can read/write their own doc
    match /usuarios_admin/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Client users collection
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // API Keys collection
    match /api_keys/{keyId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // Campaigns collection
    match /campanias/{campaignId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Global leads collection
    match /leads/{leadId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Products collection - read is public for demo pages, write requires auth
    match /productos/{productId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // CRM events
    match /crm_events/{eventId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Revenue tracking
    match /revenue/{revenueId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Team members
    match /team_members/{memberId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.owner_user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner_user_id;
    }

    // Team invites
    match /team_invites/{inviteId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.owner_user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner_user_id;
    }

    // Generated content
    match /generated_content/{docId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Message events
    match /message_events/{docId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // A/B tests
    match /ab_tests/{docId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }

    // Support tickets
    match /support_tickets/{ticketId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if true;
    }

    // Chat messages
    match /chat_messages/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if true;
    }

    // Demo configurations
    match /config_demos/{nicheId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Public demos (for demo pages)
    match /demos/{demoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Landing views tracking
    match /landing_views/{viewId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Landing engagement tracking
    match /landing_engagement/{engagementId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Notifications
    match /notificaciones/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Health check
    match /_health/{docId} {
      allow read, write: if true;
    }
  }
}
